# autoscientist environment variables
# Copy to .env (gitignored) OR export in ~/.bashrc.
# Both are read; ~/.bashrc takes precedence for interactive shells.

# REQUIRED — Anthropic API key for Claude calls.
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — Ollama OpenAI-compatible base URL.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# OPTIONAL — Override monthly budget cap (USD). Default 150.
# AUTOSCIENTIST_MONTHLY_CAP_USD=150

# OPTIONAL — Override budget hard-floor buffer (USD). Default 5.
# AUTOSCIENTIST_BUDGET_BUFFER_USD=5

# OPTIONAL — Path to the autoscientist SQLite DB. Default <repo_root>/autoscientist.db.
# AUTOSCIENTIST_DB_PATH=/mnt/d/autoscientist/autoscientist.db

# OPTIONAL — GitHub Personal Access Token for the repo_publisher agent, which
# publishes the curated release tree to GitHub via the GitHub MCP server
# (config/mcp.toml). Without it, repo_publisher still writes the local release
# tree and simply skips the GitHub push.
#   - Fine-grained PAT: Administration: Read/write (create repos) +
#     Contents: Read/write (push files). Classic PAT: the `repo` scope.
# GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...
