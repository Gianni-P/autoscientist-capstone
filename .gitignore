# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual envs / uv
.venv/
.python-version

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Secrets and local config
# Ignore .env, .env.save, .env.local, etc. but keep the documented template.
.env
.env.*
!.env.example
*.local.toml
.claude/settings.local.json

# SQLite (project state)
*.db
*.db-shm
*.db-wal

# Run artifacts
runs/
runs_*/
*.log
*.jsonl

# Large / reproducible data kept OUT of git (backed up or re-fetchable elsewhere).
# /data is a symlink to the 100GB+ dataset store; backups/ holds local DB
# snapshots (the DB is the experimental record — back it up separately);
# messages_dump.txt is a large local debug dump.
/data
backups/
messages_dump.txt
projects_smoke_*/

# Project-scoped artifacts (fetched datasets, sandbox outputs, generated PDFs).
# The small per-project metadata (kickoff_payload.json, config.toml, README.md,
# STATE_OF_PLAY.md, paper/, release/) is intentionally kept and committed.
projects/*/sandbox/
projects/*/data/
projects/*/datasets/
projects/*/exec_logs/
projects/*/phase8_artifacts/
projects/*/figures/
projects/*/cache/
projects/*/build/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Submission hygiene: local-only scratch, not part of the published project ---
# Internal capstone strategy notes (the public project report is WRITEUP.md).
CAPSTONE.md
# Ad-hoc / debug scripts: the underscore convention marks scratch, and these
# named one-offs drove specific math693a runs. Kept local; not reusable code.
# (Already-tracked scripts such as scripts/_budget_status_v2.py stay committed —
# .gitignore never untracks an existing file.)
scripts/_*
scripts/advance_*.py
scripts/finalize_*.py
scripts/assemble_final_paper.py
scripts/implement_e2_e5.py
scripts/kickoff_full.py
scripts/regen_code_qwen3_guided.py
scripts/rerun_paper_writer.py
scripts/restart_codegen_opus.py
scripts/resume_e2_e5_revision.py
scripts/strengthen_e2_e5.py
# Per-project archives and LaTeX build artifacts (keep .tex sources and the .pdf)
projects/*/_archive_*/
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# Local Kaggle-submission prep + one-off scratch (mirrors CAPSTONE.md above):
# the graded report is WRITEUP.md. These are the local video script, the
# slide-deck generation prompt, a stray operator instruction note, and a local
# demo-serve helper — none are part of the published project.
VIDEO_SCRIPT.md
PRESENTATION_PROMPT.md
/.cp_instr.txt
/_serve_demo.sh
# Redundant screenshot archives — the individual PNGs under docs/screenshots/
# are tracked; the .zip bundles are duplicates.
*.zip
